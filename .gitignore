# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Production
/build

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# Environment files - IMPORTANT: Keep .env.example but ignore secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# API Keys and Secrets
*.key
*.pem
*.cert
credentials.json
google-credentials.json
aws-credentials.json

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Database files
/data/*.db
/data/*.db-shm
/data/*.db-wal
*.sqlite
*.sqlite3

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db

